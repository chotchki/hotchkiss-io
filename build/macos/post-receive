#!/bin/bash
# Bare-repo post-receive hook: dispatches by the pushed ref.
#
#   refs/heads/main  -> beta  (Hotchkiss-IO-Beta.app / io.hotchkiss.web.beta)
#                             bleeding edge, rebuilt on every main push
#   refs/tags/v*     -> prod  (Hotchkiss-IO.app      / io.hotchkiss.web)
#                             deliberate promotion, only a version tag ships it
#   anything else    -> ignored
#
# Caller (git) sets GIT_DIR to the bare repo. For each deploying ref we extract
# that tree into a per-profile work dir (wiped each run), set CARGO_TARGET_DIR
# so cargo reuses incremental artifacts across pushes of the same profile, then
# hand off to build.sh --profile. Per-profile src + target dirs mean a main push
# and a tag push that land close together never clobber each other's build state.
#
# On any failure before the swap, the running app keeps serving.
set -euo pipefail

# Hooks inherit a stripped PATH from sshd. Add the locations cargo / rustup /
# launchctl / homebrew tools live so build.sh can find them.
export PATH="$HOME/.cargo/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Signing config (Phase CP), OUTSIDE the repo + absent on dev/CI. It exports
# CODESIGN_IDENTITY (a Developer ID). When set, deploy() re-signs the built app
# with that identity so the macOS Full Disk Access (TCC) grant survives deploys
# (ad-hoc's cdhash changes every build → the grant drops, hanging external-volume
# media). codesign can't reach the keychain from THIS non-GUI sshd hook, so the
# re-sign is delegated to a GUI-session agent (sign_with_devid below). One-time
# setup (cert + key-partition-list + the signer LaunchAgent) is in SETUP.md §9.
[ -f "$HOME/.config/hotchkiss-io/build.env" ] && . "$HOME/.config/hotchkiss-io/build.env"

WORK_ROOT="$HOME/.cache/hotchkiss-io-build"
# Per-deploy build logs (the build's combined stdout+stderr) land here, pruned to
# the most recent KEEP_LOGS per profile — so a failed deploy stays debuggable after
# the push window closes (the build also still streams live to the pushing client).
LOG_DIR="$HOME/Library/Logs/hio-deploy"
KEEP_LOGS=5

# media_roots_of <config.json> — print each media_paths entry (expanded), one per
# line; nothing if the file or the key is missing/unparseable.
media_roots_of() {
    python3 -c '
import json, os, sys
try:
    cfg = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
for r in (cfg.get("media_paths") or []):
    print(os.path.expanduser(r))
' "$1" 2>/dev/null
}

# sign_with_devid <app_path>
#
# Re-sign the built app with the Developer ID. codesign fails from THIS non-GUI
# sshd hook (errSecInternalComponent — it can't unlock the keychain key, and
# `launchctl asuser` into the GUI session needs root), so hand the app to the
# io.hotchkiss.signer LaunchAgent running in the logged-in GUI session: drop a
# request file (it WatchPaths the dir) and wait for its result. Returns non-zero
# on failure or timeout, so a signing problem ABORTS the deploy rather than
# shipping an ad-hoc binary that would silently drop the Full Disk Access grant.
sign_with_devid() {
    local app="$1"
    local sdir="$HOME/.config/hotchkiss-io/sign"
    local token; token="$(basename "$app" .app).$$"
    local req="$sdir/requests/$token.request"
    local res="$sdir/results/$token.result"

    mkdir -p "$sdir/requests" "$sdir/results"
    rm -f "$res"
    printf '%s' "$app" > "$req"           # WatchPaths fires io.hotchkiss.signer

    local waited=0
    while [[ ! -f "$res" && $waited -lt 60 ]]; do
        sleep 1; waited=$((waited + 1))
        # Belt-and-suspenders: if a coalesced WatchPaths event missed, nudge the
        # agent every 10s (a no-op if it's already running / mid-sign).
        if [[ $((waited % 10)) -eq 0 ]]; then
            launchctl kickstart "gui/$(id -u)/io.hotchkiss.signer" 2>/dev/null || true
        fi
    done

    if [[ ! -f "$res" ]]; then
        rm -f "$req"
        echo "post-receive: signer timed out after ${waited}s — is io.hotchkiss.signer loaded and the mini logged in?" >&2
        return 1
    fi
    local out; out="$(cat "$res")"; rm -f "$res"
    case "$out" in
        OK*) echo "post-receive: Developer ID re-signed via signer agent" >&2; return 0 ;;
        *)   echo "post-receive: signer reported: $out" >&2; return 1 ;;
    esac
}

# deploy <newsha> <profile> <app_dst> <launch_label>
#
# Build the pushed tree with build.sh --profile, then atomically swap the bundle
# into /Applications and kickstart the LaunchAgent. Aborts (leaving the running
# app untouched) on any failure before the swap.
deploy() {
    local newsha="$1" profile="$2" app_dst="$3" launch_label="$4"
    local src_dir="$WORK_ROOT/$profile/src"
    local app_prev="$app_dst.prev"
    export CARGO_TARGET_DIR="$WORK_ROOT/$profile/target"

    # Serialize deploys of THIS profile. Overlapping pushes (or one operator
    # double-pushing) otherwise race the bundle swap below: three concurrent
    # `mv`s nested the .app into .app.prev and left /Applications with NO live
    # bundle — beta down, while a racer still printed "deployed". macOS has no
    # `flock`, but `mkdir` is atomic; spin until we own the lock, with a
    # stale-break so a crashed deploy can't wedge the next push forever. Per
    # profile (beta + prod never block each other); released on subshell exit.
    local lock_dir="/tmp/hio-deploy-$profile.lock"
    local lock_waited=0
    until mkdir "$lock_dir" 2>/dev/null; do
        if (( lock_waited >= 600 )); then
            echo "post-receive: $profile deploy lock held >600s; breaking stale lock" >&2
            rm -rf "$lock_dir"
        else
            echo "post-receive: another $profile deploy in progress; waiting…" >&2
            sleep 5
            lock_waited=$(( lock_waited + 5 ))
        fi
    done
    trap 'rm -rf "$lock_dir"' EXIT

    echo "post-receive: deploying $newsha -> $profile" >&2

    rm -rf "$src_dir"
    mkdir -p "$src_dir"
    git archive --format=tar "$newsha" | tar -x -C "$src_dir"

    cd "$src_dir"

    # Per-deploy build log: combined stdout+stderr, kept to the most recent
    # KEEP_LOGS per profile. A failed deploy can then be read back here long after
    # the push disconnected (the build still streams live to the client too).
    mkdir -p "$LOG_DIR"
    local logfile="$LOG_DIR/${profile}-$(date +%Y%m%d-%H%M%S).log"
    ls -1t "$LOG_DIR/${profile}-"*.log 2>/dev/null | tail -n "+$((KEEP_LOGS + 1))" | xargs rm -f 2>/dev/null || true
    echo "=== deploy $profile $newsha @ $(date) ===" > "$logfile"

    # build.sh prints BUILT_APP=<absolute-path> on success. Declare first so the
    # command-substitution's exit status isn't masked by `local` (set -e + the
    # pipefail above then abort the deploy if the build fails). `2>&1` folds cargo's
    # stderr — where compile errors print — into the tee'd log + client stream.
    local built
    built=$(./build/macos/build.sh --profile "$profile" 2>&1 | tee -a "$logfile" /dev/stderr | awk -F= '/^BUILT_APP=/ {print $2}')
    if [[ -z "$built" || ! -d "$built" ]]; then
        echo "post-receive: build.sh did not produce a usable app bundle for $profile" >&2
        exit 1
    fi

    # Developer ID re-sign (Phase CP): build.sh ad-hoc-signs so the app RUNS, but
    # the durable Full Disk Access (TCC) grant needs a STABLE Developer ID
    # signature. codesign can't reach the keychain from this non-GUI sshd hook, so
    # hand the built app to the GUI-session signer agent. Re-source build.env HERE
    # (not only at top level) so CODESIGN_IDENTITY is reliably set in this subshell.
    [ -f "$HOME/.config/hotchkiss-io/build.env" ] && . "$HOME/.config/hotchkiss-io/build.env"
    if [[ -n "${CODESIGN_IDENTITY:-}" ]]; then
        echo "post-receive: re-signing $profile with Developer ID via signer agent" >&2
        sign_with_devid "$built" \
            || { echo "post-receive: Developer ID signing FAILED for $profile; aborting before swap (running app untouched)" >&2; exit 1; }
    else
        echo "post-receive: CODESIGN_IDENTITY unset — $profile shipped AD-HOC (Full Disk Access will drop)" >&2
    fi

    # Beta boots on fresh prod data: snapshot prod's DB into beta's path
    # (sessions reset, beta's own cert preserved) before the kickstart. (12.5)
    if [[ "$profile" == beta ]]; then
        snapshot_prod_db_into_beta
    fi

    # Atomic-ish swap: rename current out, rename new in, restart, drop old.
    # The mmap'd binary keeps the old process alive across the rename until the
    # SIGTERM restart below swaps it for the new one.
    rm -rf "$app_prev"
    if [[ -d "$app_dst" ]]; then
        mv "$app_dst" "$app_prev"
    fi
    mv "$built" "$app_dst"
    # Never restart the agent onto a non-bundle. `set -e` catches an mv ERROR but
    # not an mv that NESTED into an existing dir (exit 0) — the failure mode that
    # took beta down silently. The per-profile lock above makes the nest
    # impossible, but a bad swap must still abort here, not relaunch onto nothing.
    if [[ ! -x "$app_dst/Contents/MacOS/hotchkiss-io" ]]; then
        echo "post-receive: $profile swap left no valid bundle at $app_dst; aborting before restart" >&2
        exit 1
    fi
    # Stop the running instance with SIGTERM, NOT `kickstart -k` (which SIGKILLs
    # the GUI tray app → macOS files a "<app> quit unexpectedly" crash report on
    # every deploy, piling dialogs up on the mini's screen). SIGTERM's default
    # disposition is a clean terminate, so no crash report; KeepAlive=true then
    # relaunches the agent onto the just-swapped bundle (after up to
    # ThrottleInterval seconds — kept deliberately so a crash-looping build can't
    # thrash). If the agent isn't loaded yet (first deploy of a profile, or after
    # a maintenance unload) `kill` exits non-zero — bootstrap it (RunAtLoad then
    # starts it) instead of letting `set -e` abort with the bundle already swapped
    # in (which would misreport a good deploy as a failed push).
    if ! launchctl kill TERM "gui/$(id -u)/$launch_label"; then
        echo "post-receive: $launch_label not loaded; bootstrapping" >&2
        launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/$launch_label.plist"
    fi
    # Do NOT rm "$app_prev" here: the SIGTERM'd old process is still shutting down
    # and is mmap'd from .prev's executable — unlinking it mid-exit makes the kernel
    # kill it with OS_REASON_CODESIGNING (a "quit unexpectedly" crash report, the
    # v0.0.84 popup). Leave .prev; the next deploy's top `rm -rf "$app_prev"`
    # reclaims it once the old process is long gone. (Hotchkiss-IO.app.prev isn't a
    # .app, so LaunchServices ignores it.)

    echo "post-receive: deployed $newsha -> $profile" >&2
}

# snapshot_prod_db_into_beta
#
# Replace beta's SQLite DB with a consistent online snapshot of LIVE prod, then:
#   - reset beta's session state (drop the session signing key — crypto_keys id 1
#     — so beta regenerates its own, plus the library-owned tower_sessions table)
#     so prod's sessions don't cross to beta, while PRESERVING the media-URL HMAC
#     key (id 2) so beta's media url_keys match prod's;
#   - drop prod's visitor log (request_log) and prod's Let's Encrypt ACME account
#     key (instant_acme_domains) — neither belongs on a public beta;
#   - preserve beta's OWN cert + ACME account (captured before the overwrite,
#     restored after) so beta never re-orders beta.hotchkiss.io from LE prod (the
#     5/week duplicate-cert limit) nor re-mints its ACME account on every push;
#   - sync prod's media store into beta's own media dir (content-addressed rsync)
#     so beta can serve the media its snapshotted rows reference.
# Users/passkeys carry over intact, so chris's prod passkey authenticates on beta
# (beta's WebAuthn rp_id is the registrable parent hotchkiss.io — see 12.1/12.6).
#
# Uses the SQLite online-backup API (.backup), NOT cp: prod is live and may be
# mid-write, and .backup yields a consistent point-in-time copy without quiescing
# prod. Needs the macOS system /usr/bin/sqlite3 (already on PATH above).
snapshot_prod_db_into_beta() {
    local prod_db="$HOME/Library/Application Support/io.hotchkiss.web/data/database.sqlite"
    local beta_db="$HOME/Library/Application Support/io.hotchkiss.web.beta/data/database.sqlite"
    local beta_domain="beta.hotchkiss.io"
    local cert_dump="$WORK_ROOT/beta/beta_certs.sql"
    local acme_dump="$WORK_ROOT/beta/beta_acme.sql"

    if [[ ! -f "$prod_db" ]]; then
        echo "post-receive: prod DB not found at $prod_db — skipping beta snapshot" >&2
        return 0
    fi

    # 1. Capture beta's own cert rows (as INSERTs) before the overwrite. First
    #    beta deploy has no beta DB yet -> empty dump -> beta orders its cert once
    #    on first boot (expected); every push thereafter preserves it.
    mkdir -p "$WORK_ROOT/beta"
    rm -f "$cert_dump" "$acme_dump"
    if [[ -f "$beta_db" ]]; then
        sqlite3 "$beta_db" ".mode insert certificates" "SELECT * FROM certificates WHERE domain = '$beta_domain';" > "$cert_dump" 2>/dev/null || true
        sqlite3 "$beta_db" ".mode insert instant_acme_domains" "SELECT * FROM instant_acme_domains WHERE domain = '$beta_domain';" > "$acme_dump" 2>/dev/null || true
    fi

    # 2. Consistent online snapshot of LIVE prod into beta's path. Replacing the
    #    file under the still-running old beta process is safe (unlink-while-open);
    #    the kickstart below restarts beta onto the new file.
    mkdir -p "$(dirname "$beta_db")"
    rm -f "$beta_db" "$beta_db-wal" "$beta_db-shm"
    sqlite3 "$prod_db" ".backup '$beta_db'"

    # 3. Scrub prod secrets/state that must not live on the public beta: session
    #    key (beta regenerates its own), visitor log (privacy), prod's LE ACME
    #    account key, and sessions. PRESERVE the media-URL HMAC key (crypto_keys
    #    id 2) — beta serves prod's snapshotted media rows (whose url_keys were
    #    HMAC'd with prod's key) + the rsync'd files (step 5), so matching the key
    #    keeps beta a true mirror; only the session signing key (id 1) is dropped.
    sqlite3 "$beta_db" "DELETE FROM crypto_keys WHERE id <> 2;"
    sqlite3 "$beta_db" "DELETE FROM request_log;"
    sqlite3 "$beta_db" "DELETE FROM instant_acme_domains;"
    sqlite3 "$beta_db" "DELETE FROM tower_sessions;" 2>/dev/null || true

    # 4. Drop prod's carried-over cert, restore beta's own cert + ACME account.
    sqlite3 "$beta_db" "DELETE FROM certificates;"
    if [[ -s "$cert_dump" ]]; then
        sqlite3 "$beta_db" < "$cert_dump"
    fi
    if [[ -s "$acme_dump" ]]; then
        sqlite3 "$beta_db" < "$acme_dump"
    fi

    # 5. Sync prod's media into beta's OWN media dir. Prod may span MULTIPLE roots
    #    (Settings.media_paths — external drives), so read them from prod's config
    #    and rsync each. Content-addressed = immutable sha-named files (and the same
    #    sha lands in the same shard regardless of which drive it's on), so beta
    #    needn't mirror the volume layout — every root's files merge into beta's one
    #    media dir; --ignore-existing copies only what's new. Non-fatal: beta still
    #    boots (some media may 404 until the next push). B2 is the real media backup
    #    (filesystem-level across all drives — the app never copies media).
    local prod_config="$HOME/Library/Application Support/io.hotchkiss.web/config.json"
    local beta_config="$HOME/Library/Application Support/io.hotchkiss.web.beta/config.json"

    # 1-for-1 media mirror. Prod and beta have MATCHING ordered media_paths (dual
    # folders: the big media on the external drive, the small media on the boot
    # disk). Pair prod_roots[i] -> beta_roots[i] so each prod root mirrors to its
    # beta counterpart on the SAME class of drive — never consolidating prod's
    # multi-drive media onto one beta disk (the v0.0.83 boot-disk-fill incident).
    local -a prod_roots=() beta_roots=()
    while IFS= read -r r; do [[ -n "$r" ]] && prod_roots+=("$r"); done < <(media_roots_of "$prod_config")
    while IFS= read -r r; do [[ -n "$r" ]] && beta_roots+=("$r"); done < <(media_roots_of "$beta_config")
    [[ ${#prod_roots[@]} -gt 0 ]] || prod_roots=("$HOME/Library/Application Support/io.hotchkiss.web/media")
    [[ ${#beta_roots[@]} -gt 0 ]] || beta_roots=("$HOME/Library/Application Support/io.hotchkiss.web.beta/media")

    local i src dst dst_idx
    for i in "${!prod_roots[@]}"; do
        src="${prod_roots[$i]}"
        # Pair by index; if beta has fewer roots, fold the extras into beta's LAST.
        dst_idx=$i
        if (( i >= ${#beta_roots[@]} )); then dst_idx=$(( ${#beta_roots[@]} - 1 )); fi
        dst="${beta_roots[$dst_idx]}"

        [[ -d "$src" ]] || continue          # prod root's drive not mounted -> skip
        # Drive-present guard on the beta target (its dir OR parent exists) so an
        # unmounted external beta root can't mkdir a phantom mountpoint onto /.
        if [[ ! -d "$dst" && ! -d "$(dirname "$dst")" ]]; then
            echo "post-receive: beta media root $dst not present (drive unmounted?) — skipping $src" >&2
            continue
        fi
        mkdir -p "$dst"
        # --max-size=2G: beta is EPHEMERAL and has no need for multi-GB assets. A
        # large media-test file (78G) lived in prod's store and was re-copied into
        # beta on EVERY deploy (and 3x over when pushes overlapped), dominating the
        # sync. Nothing real on the site approaches 2G (images are KBs, web videos
        # tens of MB), so skip the giants on beta only — prod + B2 still keep them.
        rsync -a --ignore-existing --exclude='.staging/' --max-size=2G "$src/" "$dst/" \
            || echo "post-receive: media rsync $src -> $dst failed (non-fatal)" >&2
    done

    echo "post-receive: snapshotted prod DB + media into beta (session key reset; media HMAC key + beta cert/ACME preserved; prod LE key scrubbed)" >&2
}

failed=0
while read -r oldsha newsha ref; do
    case "$ref" in
        refs/heads/main)
            # Subshell-isolate each ref (a single push can carry main AND a v*
            # tag) so one ref's failure can't abort the others; </dev/null keeps
            # the build from consuming the loop's ref list on stdin.
            ( deploy "$newsha" beta "/Applications/Hotchkiss-IO-Beta.app" "io.hotchkiss.web.beta" ) </dev/null \
                || { echo "post-receive: beta deploy of $newsha FAILED" >&2; failed=1; }
            ;;
        refs/tags/v*)
            ( deploy "$newsha" prod "/Applications/Hotchkiss-IO.app" "io.hotchkiss.web" ) </dev/null \
                || { echo "post-receive: prod deploy of $newsha FAILED" >&2; failed=1; }
            ;;
        *)
            echo "post-receive: ignoring push to $ref (main -> beta, v* tag -> prod)" >&2
            ;;
    esac
done
exit "$failed"
